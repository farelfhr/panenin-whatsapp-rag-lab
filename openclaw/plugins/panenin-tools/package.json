{
  "name": "@panenin/openclaw-panenin-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.js.map",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "openclaw:cli": "node scripts/openclaw-cli.mjs",
    "plugin:generate": "npm run build && npm run openclaw:cli -- plugins build --entry ./dist/index.js --root .",
    "plugin:build": "npm run build && npm run openclaw:cli -- plugins build --entry ./dist/index.js --root . --check",
    "plugin:validate": "npm run plugin:build && npm run openclaw:cli -- plugins validate --entry ./dist/index.js --root .",
    "test": "vitest run"
  },
  "dependencies": {
    "typebox": "^1.3.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "openclaw": "^2026.7.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1",
      "minGatewayVersion": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "pluginSdkVersion": "2026.7.1"
    }
  },
  "engines": {
    "node": ">=24.15.0 <25"
  }
}
