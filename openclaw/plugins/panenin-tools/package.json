{
  "name": "@panenin/openclaw-panenin-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist/index.bundle.js",
    "dist/index.d.ts",
    "dist/index.bundle.js.map",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.bundle.js --root .",
    "plugin:validate": "npm run plugin:build && openclaw plugins validate --entry ./dist/index.bundle.js --root .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.0",
    "openclaw": "^2026.7.1",
    "typebox": "^1.3.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.bundle.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1",
      "minGatewayVersion": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "pluginSdkVersion": "2026.7.1"
    }
  },
  "engines": {
    "node": ">=24.15.0 <25"
  }
}
