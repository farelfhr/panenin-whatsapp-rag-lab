{
  "name": "panenin-whatsapp-rag-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Isolated Groq chat, Gemini embedding RAG, OpenClaw, and Fonnte WhatsApp integration lab for Panenin.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:gemini": "tsx scripts/test-gemini.ts",
    "test:embedding": "tsx scripts/test-embedding.ts",
    "test:groq": "tsx scripts/test-groq.ts",
    "test:olagon": "tsx scripts/test-olagon.ts",
    "test:openclaw": "tsx scripts/test-openclaw.ts",
    "test:openclaw:rag": "tsx scripts/test-openclaw-rag.ts",
    "test:openclaw:conversation": "tsx scripts/test-openclaw-conversation.ts",
    "test:openclaw:natural": "tsx scripts/test-openclaw-natural.ts",
    "openclaw:gateway": "tsx scripts/start-openclaw.ts",
    "demo": "tsx scripts/demo.ts",
    "demo:check": "tsx scripts/demo.ts --check",
    "rag:ingest": "tsx scripts/ingest-knowledge.ts",
    "rag:test": "tsx scripts/test-rag.ts",
    "fonnte:test": "tsx scripts/test-fonnte-send.ts",
    "fonnte:inspect": "tsx scripts/inspect-fonnte-payload.ts",
    "fonnte:activate": "tsx scripts/activate-fonnte.ts",
    "dev": "tsx watch src/index.ts",
    "dev:tools": "tsx watch src/internal-tools/server.ts",
    "plugin:build": "npm --prefix openclaw/plugins/panenin-tools run plugin:build",
    "plugin:test": "npm --prefix openclaw/plugins/panenin-tools test",
    "plugin:validate": "npm --prefix openclaw/plugins/panenin-tools run plugin:validate",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.110.7",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
